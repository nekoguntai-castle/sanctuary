{
  "name": "sanctuary-server",
  "version": "0.8.43",
  "description": "Backend API server for Sanctuary Bitcoin Wallet",
  "main": "dist/server/src/index.js",
  "engines": {
    "node": ">=24 <25"
  },
  "prisma": {
    "seed": "node --experimental-specifier-resolution=node dist/prisma/seed.js"
  },
  "overrides": {
    "@hono/node-server": "1.19.14",
    "hono": "4.12.14",
    "protobufjs": "7.5.5",
    "uuid": "14.0.0"
  },
  "scripts": {
    "postinstall": "prisma generate",
    "predev": "node scripts/ensure-shared-module-resolution.mjs",
    "dev": "tsx watch src/index.ts",
    "prebuild": "node scripts/ensure-shared-module-resolution.mjs && prisma generate",
    "build": "tsc",
    "prestart": "node scripts/ensure-shared-module-resolution.mjs",
    "start": "node dist/server/src/index.js",
    "pretest": "node scripts/ensure-shared-module-resolution.mjs && prisma generate",
    "test": "vitest",
    "pretest:run": "node scripts/ensure-shared-module-resolution.mjs",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "pretest:coverage": "node scripts/ensure-shared-module-resolution.mjs",
    "test:coverage": "vitest run --coverage",
    "pretest:unit": "node scripts/ensure-shared-module-resolution.mjs",
    "test:unit": "vitest run tests/unit",
    "pretest:integration": "node scripts/ensure-shared-module-resolution.mjs",
    "test:integration": "vitest run tests/integration --no-file-parallelism --maxWorkers 1",
    "test:integration:db": "../scripts/run-integration-tests.sh",
    "pretest:ci": "node scripts/ensure-shared-module-resolution.mjs",
    "test:ci": "vitest run --coverage --reporter=junit",
    "pretest:bitcoin": "node scripts/ensure-shared-module-resolution.mjs",
    "test:bitcoin": "vitest run tests/unit/services/bitcoin",
    "pretest:pool": "node scripts/ensure-shared-module-resolution.mjs",
    "test:pool": "vitest run tests/unit/services/bitcoin/electrumPool.test.ts tests/unit/services/bitcoin/nodeClient.test.ts",
    "pretest:api": "node scripts/ensure-shared-module-resolution.mjs",
    "test:api": "vitest run tests/unit/api",
    "pretest:contract": "node scripts/ensure-shared-module-resolution.mjs",
    "test:contract": "vitest run tests/contract",
    "pretest:security": "node scripts/ensure-shared-module-resolution.mjs",
    "test:security": "vitest run --testNamePattern='Authentication|Encryption|Two-Factor|Password'",
    "pretest:fast": "node scripts/ensure-shared-module-resolution.mjs",
    "test:fast": "vitest run --changed",
    "test:debug": "vitest --inspect-brk --no-file-parallelism",
    "pretest:mutation": "node scripts/ensure-shared-module-resolution.mjs",
    "test:mutation": "stryker run",
    "pretest:mutation:critical": "node scripts/ensure-shared-module-resolution.mjs",
    "test:mutation:critical": "stryker run stryker.critical.config.mjs",
    "test:mutation:critical:gate": "npm run test:mutation:critical && node scripts/mutation/check-critical-mutation-gate.mjs",
    "pretypecheck:tests": "node scripts/ensure-shared-module-resolution.mjs",
    "typecheck:tests": "tsc --noEmit -p tsconfig.test.json --pretty false",
    "pretypecheck:tests:full": "node scripts/ensure-shared-module-resolution.mjs",
    "typecheck:tests:full": "tsc --noEmit -p tsconfig.test.full.json --pretty false",
    "lint": "cd .. && npm run lint:server",
    "check:prisma-imports": "tsx scripts/check-prisma-imports.ts",
    "prepare": "cd .. && husky server/.husky",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:studio": "prisma studio",
    "prisma:seed": "tsx prisma/seed.ts"
  },
  "keywords": [
    "bitcoin",
    "wallet",
    "api",
    "sanctuary"
  ],
  "author": "nekoguntai",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opentelemetry/auto-instrumentations-node": "^0.73.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.215.0",
    "@opentelemetry/resources": "^2.6.1",
    "@opentelemetry/sdk-node": "^0.215.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "axios": "^1.7.9",
    "bcryptjs": "^3.0.3",
    "bip32": "^5.0.1",
    "bitcoinjs-lib": "^7.0.1",
    "bullmq": "^5.73.3",
    "compression": "^1.8.1",
    "cookie": "^1.0.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.6",
    "csrf-csrf": "^4.0.3",
    "dotenv": "^17.4.1",
    "express": "^5.2.1",
    "express-rate-limit": "^8.3.2",
    "helmet": "^8.1.0",
    "i18next": "^26.0.3",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.2",
    "nodemailer": "^8.0.4",
    "otplib": "^13.4.0",
    "prom-client": "^15.1.3",
    "qrcode": "^1.5.4",
    "socks": "^2.8.7",
    "socks-proxy-agent": "^10.0.0",
    "tiny-secp256k1": "^2.2.3",
    "ws": "^8.18.0",
    "zod": "^4.3.4"
  },
  "devDependencies": {
    "@faker-js/faker": "^10.4.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^24.12.2",
    "@types/nodemailer": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/supertest": "^7.2.0",
    "@types/ws": "^8.5.10",
    "@vitest/coverage-v8": "^4.1.4",
    "ecpair": "^3.0.1",
    "fast-check": "^4.5.3",
    "husky": "^9.1.7",
    "prisma": "^7.6.0",
    "supertest": "^7.1.4",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "vitest": "^4.1.4"
  }
}
