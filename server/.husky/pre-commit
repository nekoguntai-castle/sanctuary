run_documentation_agent() {
    if ! command -v claude >/dev/null 2>&1; then
        return 0
    fi

    DOC_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' | grep -vE '(\.test\.|\.spec\.|/tests/)' || true)
    if [ -z "$DOC_FILES" ]; then
        return 0
    fi

    CRITICAL_FILES=$(echo "$DOC_FILES" | grep -E '(bitcoin|crypto|key|sign|wallet|descriptor|address|transaction|auth|password|token|secret)' || true)

    # Skip for small non-security diffs
    if [ -z "$CRITICAL_FILES" ]; then
        DIFF_LINES=$(git diff --cached --stat | tail -1 | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo "0")
        if [ "$DIFF_LINES" -lt 50 ]; then
            return 0
        fi
    fi

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${BLUE}📚 Code Documentation Analysis${NC}"
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    DOC_DIFF=$(git diff --cached -- $DOC_FILES)
    PROMPT="PRE-COMMIT DOCUMENTATION REVIEW.

$AGENT_OUTPUT_RULES

REVIEW STANDARDS:
- Security-critical code (crypto, keys, signing, auth) MUST be documented with the WHY, not the what.
- Complex algorithms or non-obvious invariants need explanatory comments.
- New exported functions/types should have JSDoc.
- Bitcoin-specific logic (descriptors, derivation paths, BIP standards, script types) needs documentation.
- DO NOT flag missing docs for obvious code — well-named identifiers document themselves.
