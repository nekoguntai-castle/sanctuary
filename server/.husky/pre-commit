#!/bin/sh

# =============================================
# Pre-commit Hook - Run Tests Before Commit
# =============================================
# This hook runs fast tests on changed files to catch issues early.
# For full test suite, run: npm run test:all
# =============================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Agent stop flags — populated from marker files after parallel wait
TEST_COVERAGE_STOP=0
UI_CONSISTENCY_STOP=0
BACKEND_QUALITY_STOP=0
DOCUMENTATION_STOP=0

echo "${YELLOW}Running pre-commit checks...${NC}"

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
GIT_DIR=$(git rev-parse --git-dir)

# =============================================
# Agent telemetry + cache infrastructure
# =============================================
# Telemetry appends one JSONL record per agent run to .claude/agent-audit.jsonl
# so verdicts (and now rubric + issues) can be reviewed to tune prompts.
# Cache short-circuits claude invocation when an identical staged diff has been
# reviewed recently (common during `git commit --amend` and rebases).
# Both live under .claude/ which is gitignored — state stays local per-dev.

AGENT_LOG_DIR="$REPO_ROOT/.claude"
AGENT_LOG_FILE="$AGENT_LOG_DIR/agent-audit.jsonl"
AGENT_CACHE_DIR="$AGENT_LOG_DIR/agent-cache"
# Bump when ANY agent prompt changes to invalidate cache globally.
# v2: switched agents from plaintext markers to structured JSON rubric + issues.
# v3: verdict derived from rubric in shell (agents' self-reported verdict
#     no longer trusted); old cache entries must be re-classified.
# v4: invalid rubric values (anything outside OK/WARN/BLOCK) now yield
#     UNKNOWN instead of silently passing as PROCEED.
# v5: non-object rubrics (array, string, number, boolean) now yield
#     UNKNOWN instead of falling through to self-reported verdict.
# v6: fail-closed gate — UNKNOWN now blocks the commit (previously it was
#     informational only, which meant malformed rubrics silently passed).
# v7: closed remaining bypass channels — empty/missing/null rubric no
#     longer falls back to self-reported verdict; plaintext marker
#     fallback removed entirely. The only path to a non-UNKNOWN verdict
#     is a non-empty rubric object with {OK,WARN,BLOCK} values.
# v8: multi-object agent output now rejected at extraction time. Every
#     extraction strategy enforces exactly-one-object via jq --slurp +
#     length==1 check; a pre-scan rejects files with multiple candidate
#     object openings. Closes the bypass where a leading "decoy" OK
#     rubric could hide a real BLOCK in a later object.
PROMPT_VERSION="v8"
# Per-commit scratch dir for parallel agent outputs and stop markers.
AGENT_TMP_DIR=$(mktemp -d -t sanctuary-agents-XXXXXX)
trap 'rm -rf "$AGENT_TMP_DIR"' EXIT

mkdir -p "$AGENT_LOG_DIR" "$AGENT_CACHE_DIR"

# TTL-sweep cache entries older than 7 days so the directory doesn't grow
# unbounded. Runs every commit — cheap operation, silent on empty cache.
find "$AGENT_CACHE_DIR" -type f -mtime +7 -delete 2>/dev/null || true

# Parse stdin and echo EXACTLY one top-level JSON object, or nothing.
# Uses --slurp to wrap all top-level JSON values into an array, then
# enforces length==1 && type=="object". This rejects:
#   - multiple top-level JSON values (multi-object output)
#   - non-object values (arrays, strings, numbers, booleans, null)
#   - parse errors (invalid JSON stream)
# Every extraction strategy pipes through this so a "decoy" leading
# object cannot hide a BLOCK rubric in a later one.
_parse_single_object() {
    jq --slurp -c '
        if length == 1 and (.[0] | type) == "object"
        then .[0]
        else empty
        end
    ' 2>/dev/null
}

# Extract the single well-formed JSON object from an agent's output file.
# LLMs sometimes wrap responses in markdown fences or add stray prose —
# we try several extraction strategies, but every one enforces the
# single-object invariant. Echoes the JSON object (compact) on success,
# or "null" on failure.
extract_json_object() {
    # $1 = path to agent output file
    local out opening_count

    # PRE-CHECK: count lines starting with optional whitespace + '{'.
    # More than one candidate object opening means the output is
    # ambiguous — we cannot know which is authoritative. Reject so
    # the gate fails closed rather than picking a potentially-decoy
    # first object.
    opening_count=$(grep -cE '^[[:space:]]*\{' "$1" 2>/dev/null || echo 0)
    if [ -n "$opening_count" ] && [ "$opening_count" -gt 1 ] 2>/dev/null; then
        echo "null"
        return
    fi

    # Strategy 1: whole file is a single JSON object
    out=$(_parse_single_object < "$1")
    if [ -n "$out" ]; then
        echo "$out"
        return
    fi

    # Strategy 2: ```json ... ``` fenced block
    out=$(sed -n '/^```json$/,/^```$/p' "$1" | sed '1d;$d' | _parse_single_object)
    if [ -n "$out" ]; then
        echo "$out"
        return
    fi

    # Strategy 3: unlabelled ``` ... ``` fenced block
    out=$(sed -n '/^```$/,/^```$/p' "$1" | sed '1d;$d' | _parse_single_object)
    if [ -n "$out" ]; then
        echo "$out"
        return
    fi

    # Strategy 4: from first `{` at column 0 to first `}` at column 0
    out=$(sed -n '/^{/,/^}$/p' "$1" | _parse_single_object)
    if [ -n "$out" ]; then
        echo "$out"
        return
    fi

    echo "null"
}

# Derive the verdict mechanically from the rubric. We do NOT trust the
# agent's self-reported `.verdict` anywhere in this function — if we did,
# a malformed rubric could be rescued by the self-reported verdict and
# silently bypass the gate. Self-reported is journaled only (for detecting
# disagreement).
#
# The rubric MUST be a non-empty object of {OK,WARN,BLOCK} values to produce
# a non-blocking verdict. Anything else → UNKNOWN (which fails the gate
# closed via the verdict_blocks_commit policy).
#
# Precedence:
#   1. rubric is not a non-empty object → UNKNOWN
#      (covers: missing, null, array, string, number, boolean, empty object)
#   2. any value = BLOCK → STOP (wins even alongside invalid values —
#      a stop is the safer error mode)
#   3. any value outside {OK,WARN,BLOCK} → UNKNOWN
#   4. any value = WARN → REVIEW
#   5. all values = OK → PROCEED
derive_verdict_from_body() {
    # $1 = JSON body
    local body="$1"
    local rubric_length values has_block has_invalid has_warn

    # Single jq expression to detect any shape other than non-empty object.
    # Emits the object's length for valid shapes, -1 otherwise. Fallback -1
    # on jq error so a broken body is treated the same as malformed.
    rubric_length=$(echo "$body" | jq -r '
        if (.rubric // null) | type == "object"
        then (.rubric | length)
        else -1
        end
    ' 2>/dev/null || echo -1)

    # Missing / null / non-object / empty-object → fail closed.
    if [ -z "$rubric_length" ] || [ "$rubric_length" = "-1" ] || [ "$rubric_length" = "0" ]; then
        echo "UNKNOWN"
        return
    fi

    # Rubric is a non-empty object. Collect values as uppercase strings so
    # comparison is case-insensitive; non-string values get stringified so
    # they land in the "invalid" bucket.
    values=$(echo "$body" | jq -c '
        .rubric | to_entries | map(
            .value | if type == "string" then ascii_upcase else tostring end
        )
    ' 2>/dev/null || echo '[]')

    # Precedence: BLOCK > invalid > WARN > OK
    has_block=$(echo "$values" | jq -r 'any(. == "BLOCK")' 2>/dev/null || echo false)
    if [ "$has_block" = "true" ]; then echo "STOP"; return; fi

    has_invalid=$(echo "$values" | jq -r 'any(. != "OK" and . != "WARN" and . != "BLOCK")' 2>/dev/null || echo false)
    if [ "$has_invalid" = "true" ]; then echo "UNKNOWN"; return; fi

    has_warn=$(echo "$values" | jq -r 'any(. == "WARN")' 2>/dev/null || echo false)
    if [ "$has_warn" = "true" ]; then echo "REVIEW"; return; fi

    # Non-empty, all valid, no BLOCK, no WARN → all OK.
    echo "PROCEED"
}

# Classify an agent's output: derive from JSON body if extractable, else
# UNKNOWN. No plaintext fallback — an agent that produces plaintext
# "RECOMMEND PROCEED" is off-format and cannot be trusted to have
# actually reviewed the diff; falling closed forces the author to look.
extract_verdict() {
    # $1 = path to agent output file
    local body
    body=$(extract_json_object "$1")
    if [ "$body" != "null" ]; then
        derive_verdict_from_body "$body"
    else
        echo "UNKNOWN"
    fi
}

# Count non-empty lines in a newline-separated list ("" → 0).
count_lines() {
    if [ -z "$1" ]; then
        echo 0
    else
        printf '%s\n' "$1" | wc -l | tr -d ' '
    fi
}

# Append one JSONL record per agent invocation. Cache hits log duration_s=0.
# Includes the parsed JSON body (rubric + issues) when extractable so the
# journal is queryable without re-parsing the raw output. Records both
# `verdict` (derived from the rubric — used for gating) and `self_verdict`
# (agent's self-reported value) so disagreements are queryable.
log_agent_run() {
    # $1=agent_name $2=verdict $3=duration_s $4=file_count $5=output_file $6=cache_hit(0|1)
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    head=$(git rev-parse HEAD 2>/dev/null || echo "unknown")
    body=$(extract_json_object "$5")
    self_verdict="UNKNOWN"
    if [ "$body" != "null" ]; then
        self_verdict=$(echo "$body" | jq -r '.verdict // "UNKNOWN"' | tr '[:lower:]' '[:upper:]')
    fi

    if command -v jq >/dev/null 2>&1; then
        jq -nc \
            --arg ts "$ts" \
            --arg head "$head" \
            --arg agent "$1" \
            --arg verdict "$2" \
            --arg self_verdict "$self_verdict" \
            --arg duration_s "$3" \
            --arg file_count "$4" \
            --arg cache_hit "$6" \
            --argjson body "$body" \
            --rawfile output "$5" \
            '{timestamp:$ts, head:$head, agent:$agent, verdict:$verdict,
              self_verdict:$self_verdict, verdict_disagrees:($verdict != $self_verdict and $self_verdict != "UNKNOWN"),
              duration_s:($duration_s|tonumber), file_count:($file_count|tonumber),
              cache_hit:($cache_hit=="1"), body:$body, output:$output}' >> "$AGENT_LOG_FILE" 2>/dev/null || true
    else
        {
            echo "---"
            echo "timestamp=$ts head=$head agent=$1 verdict=$2 self_verdict=$self_verdict duration_s=$3 file_count=$4 cache_hit=$6"
            cat "$5"
        } >> "$AGENT_LOG_FILE" 2>/dev/null || true
    fi
}

# Render a parsed JSON agent response as friendly coloured output.
# Falls back to the raw file contents if JSON couldn't be extracted —
# important so off-format responses don't vanish into the void.
render_agent_body() {
    # $1 = path to agent output file
    local body verdict rubric_entries issue_count
    body=$(extract_json_object "$1")
    if [ "$body" = "null" ]; then
        cat "$1"
        return
    fi

    # Show the DERIVED verdict (from the rubric) in the banner — that's the
    # one used for gating. If the agent self-reported a different verdict,
    # surface the disagreement so the author can see the agent contradicted
    # its own rubric.
    verdict=$(derive_verdict_from_body "$body")
    self_verdict=$(echo "$body" | jq -r '.verdict // "UNKNOWN"' | tr '[:lower:]' '[:upper:]')
    case "$verdict" in
        STOP)    printf '%b\n' "${RED}❌ RECOMMEND STOP${NC}" ;;
        REVIEW)  printf '%b\n' "${YELLOW}⚠️  SUGGEST REVIEW${NC}" ;;
        PROCEED) printf '%b\n' "${GREEN}✅ RECOMMEND PROCEED${NC}" ;;
        *)       printf '%b\n' "${RED}⛔ UNKNOWN — malformed or unparseable output (blocking gate)${NC}" ;;
    esac
    if [ "$self_verdict" != "UNKNOWN" ] && [ "$self_verdict" != "$verdict" ]; then
        printf '%b\n' "${YELLOW}(agent self-reported ${self_verdict}; overridden by rubric-derived ${verdict})${NC}"
    fi

    rubric_entries=$(echo "$body" | jq -r '.rubric // {} | to_entries[] | "\(.key)|\(.value)"')
    if [ -n "$rubric_entries" ]; then
        echo ""
        printf '%b\n' "${BLUE}Rubric:${NC}"
        echo "$rubric_entries" | while IFS='|' read -r concern status; do
            case "$status" in
                OK)    printf '  %b✓%b %s: OK\n' "$GREEN" "$NC" "$concern" ;;
                WARN)  printf '  %b!%b %s: WARN\n' "$YELLOW" "$NC" "$concern" ;;
                BLOCK) printf '  %b✗%b %s: BLOCK\n' "$RED" "$NC" "$concern" ;;
                *)     printf '  ? %s: %s\n' "$concern" "$status" ;;
            esac
        done
    fi

    issue_count=$(echo "$body" | jq -r '.issues // [] | length')
    if [ "$issue_count" -gt 0 ]; then
        echo ""
        printf '%b\n' "${BLUE}Issues (${issue_count}):${NC}"
        echo "$body" | jq -r '.issues[] | "  [\(.severity // "?")] \(.file // "?"):\(.line // 0) — \(.note // "")"'
    fi
}

# Shared prompt prefix: output rules + schema + verdict derivation.
# Used verbatim in every agent prompt so rubric structure is consistent
# and verdict computation is mechanical (not left to LLM judgement).
# Anti-sycophancy clauses:
#  - Forbid prose/summaries — agents often waste tokens narrating the diff.
#  - Forbid markdown fences — complicates JSON extraction.
#  - Specify file:line for every issue — agents will otherwise produce
#    vague commentary that can't be acted on.
AGENT_OUTPUT_RULES='OUTPUT RULES (follow strictly):

1. Return ONLY a JSON object. No markdown fences. No prose before or after. No explanation of what the code does. No summary of the diff.

2. Schema:
{
  "rubric": { "<concern_name>": "OK" | "WARN" | "BLOCK" },
  "verdict": "STOP" | "REVIEW" | "PROCEED",
  "issues": [
    { "file": "<path>", "line": <int>, "severity": "high" | "medium" | "low", "note": "<one sentence>" }
  ]
}

3. Verdict is MECHANICAL, not judgment:
   - any rubric value = BLOCK  → verdict = STOP
   - any rubric value = WARN   → verdict = REVIEW
   - all rubric values = OK    → verdict = PROCEED

4. issues[] must reference a real file and line visible in the diff. Empty array is correct when there are no concrete issues. Do not invent issues to fill the list. Do not list stylistic nits. Do not restate what the code does.

5. Use BLOCK sparingly — only for changes that will cause a production incident, security vulnerability, data loss, or make the code unmaintainable. WARN is for concerns the author should consider; OK means no concern.'

# NOTE: DIFF_HASH is computed AFTER check_version_sync (below), because that
# function may `git add` version files and thereby change the staged diff.
# Computing it here would key the cache on the pre-sync diff while the agents
# review the post-sync diff — a silent correctness bug.
DIFF_HASH=""

# Fail-closed gate decision: STOP obviously blocks; UNKNOWN also blocks
# because it's the result of a malformed rubric, malformed JSON, or an
# agent that ignored the output format entirely. In any of those cases
# we have no reliable signal — proceeding would silently skip real review.
# REVIEW / PROCEED pass through.
verdict_blocks_commit() {
    case "$1" in
        STOP|UNKNOWN) return 0 ;;
        *) return 1 ;;
    esac
}

# Split the gate decision into two functions. The marker is the ONLY
# operation that must run for the gate to block — everything else is UI.
# By touching the marker before render/log/cache, we guarantee that any
# subsequent shell failure (render errors on weird output, log-file
# permission issue, disk-full on cp) cannot silently drop a STOP/UNKNOWN
# verdict. touch is wrapped in `|| true` for the same reason.
ensure_gate_decision() {
    # $1=verdict  $2=stop_marker_basename
    if verdict_blocks_commit "$1"; then
        touch "$AGENT_TMP_DIR/${2}.stop" 2>/dev/null || true
    fi
}

# UI-only banner printed after the agent's rendered output, so the user
# sees: rubric → issues → blocking notice in natural reading order.
print_gate_banner() {
    # $1=verdict  $2=agent_name
    if verdict_blocks_commit "$1"; then
        echo ""
        case "$1" in
            STOP)    printf '%b\n' "${RED}❌ ${2} agent recommends stopping.${NC}" ;;
            UNKNOWN) printf '%b\n' "${RED}⛔ ${2} agent output was unparseable or malformed — failing closed.${NC}" ;;
        esac
        printf '%b\n' "${YELLOW}To bypass: git commit --no-verify${NC}"
    fi
}

# Run the agent unless the same (diff, agent, prompt-version) tuple has a
# cached verdict — in which case replay the cached output and skip claude.
# $1=agent_name $2=claude_agent_type(empty=general) $3=prompt
# $4=file_count $5=stop_marker_basename
# Writes to stdout: rendered verdict + rubric + issues (or raw output if
# unparseable). Touches $AGENT_TMP_DIR/$5.stop when the verdict blocks.
invoke_agent_with_cache() {
    local agent_name="$1"
    local claude_agent="$2"
    local prompt="$3"
    local file_count="$4"
    local stop_name="$5"

    local cache_file="$AGENT_CACHE_DIR/${PROMPT_VERSION}-${DIFF_HASH}-${agent_name}.txt"

    if [ -f "$cache_file" ]; then
        local verdict
        verdict=$(extract_verdict "$cache_file")
        # Defensive: extract_verdict always echoes a value, but if something
        # goes catastrophically wrong default to UNKNOWN (fail closed).
        verdict="${verdict:-UNKNOWN}"
        # CRITICAL: set the gate marker before any UI/logging operation.
        # Any failure below (render error, log write, etc.) must NOT drop
        # the STOP/UNKNOWN signal.
        ensure_gate_decision "$verdict" "$stop_name"

        render_agent_body "$cache_file" || true
        echo ""
        printf '%b\n' "${CYAN}(cache hit — identical diff reviewed previously)${NC}"
        print_gate_banner "$verdict" "$agent_name"
        log_agent_run "$agent_name" "$verdict" 0 "$file_count" "$cache_file" 1 || true
        return 0
    fi

    local start_time temp_output duration verdict
    start_time=$(date +%s)
    temp_output=$(mktemp)

    # `|| true` prevents set -e from aborting if claude itself errors —
    # we still want other agents to finish and an UNKNOWN verdict logged
    # (which will then block via the fail-closed policy).
    if [ -n "$claude_agent" ]; then
        echo "$prompt" | claude --agent "$claude_agent" --print > "$temp_output" 2>&1 || true
    else
        echo "$prompt" | claude --print > "$temp_output" 2>&1 || true
    fi

    duration=$(( $(date +%s) - start_time ))
    verdict=$(extract_verdict "$temp_output")
    verdict="${verdict:-UNKNOWN}"
    # CRITICAL: gate marker BEFORE render/log/cache. Any failure in those
    # downstream operations (render on weird output, disk-full on cp,
    # journal write error) must not silently drop a blocking verdict.
    ensure_gate_decision "$verdict" "$stop_name"

    render_agent_body "$temp_output" || cat "$temp_output" 2>/dev/null || true
    print_gate_banner "$verdict" "$agent_name"
    log_agent_run "$agent_name" "$verdict" "$duration" "$file_count" "$temp_output" 0 || true
    cp "$temp_output" "$cache_file" 2>/dev/null || true
    rm -f "$temp_output" 2>/dev/null || true
}

# =============================================
# Skip AI agents during non-interactive git ops
# =============================================
# Rebase/cherry-pick/merge replay commits without a human reviewing output,
# so AI agent feedback is wasted compute. Still run tests + version sync.

SKIP_AI_AGENTS=0
# Note: REBASE_HEAD intentionally excluded — git leaves it behind after a
# completed rebase, so it's unreliable. The rebase-merge/ and rebase-apply/
# directories are the authoritative "rebase in progress" signals.
if [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ] \
   || [ -f "$GIT_DIR/MERGE_HEAD" ] \
   || [ -d "$GIT_DIR/rebase-merge" ] \
   || [ -d "$GIT_DIR/rebase-apply" ]; then
    SKIP_AI_AGENTS=1
fi

# =============================================
# Version Sync Check & Auto-Fix
# =============================================
# Verify all package.json and umbrel-app.yml versions are in sync
# If mismatched, automatically sync to root package.json version

check_version_sync() {
    cd "$REPO_ROOT"

    # Get root version
    ROOT_VER=$(grep '"version"' package.json | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')

    # Check each file
    SERVER_VER=$(grep '"version"' server/package.json | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')
    GATEWAY_VER=$(grep '"version"' gateway/package.json | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')
    UMBREL_VER=$(grep '^version:' sanctuary/umbrel-app.yml | sed 's/version: "\([^"]*\)"/\1/')

    if [ "$ROOT_VER" != "$SERVER_VER" ] || [ "$ROOT_VER" != "$GATEWAY_VER" ] || [ "$ROOT_VER" != "$UMBREL_VER" ]; then
        echo ""
        echo "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo "${YELLOW}🔄 Version Mismatch Detected - Auto-syncing...${NC}"
        echo "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo "  package.json:             $ROOT_VER"
        echo "  server/package.json:      $SERVER_VER"
        echo "  gateway/package.json:     $GATEWAY_VER"
        echo "  sanctuary/umbrel-app.yml: $UMBREL_VER"
        echo ""
        echo "${CYAN}Syncing all versions to $ROOT_VER...${NC}"

        # Run the bump script to sync versions
        if ./scripts/bump-version.sh "$ROOT_VER" > /dev/null 2>&1; then
            echo "${GREEN}✓ Versions synced to $ROOT_VER${NC}"

            # Stage the updated version files
            git add package.json server/package.json gateway/package.json sanctuary/umbrel-app.yml
            echo "${GREEN}✓ Version files staged for commit${NC}"
        else
            echo "${RED}Failed to sync versions. Please run manually:${NC}"
            echo "${YELLOW}  ./scripts/bump-version.sh $ROOT_VER${NC}"
            exit 1
        fi
        echo ""
    fi
}

check_version_sync

# Hash the (possibly just-modified) staged diff. Serves as the cache key so
# amend-retry and identical rebase replays short-circuit claude invocation.
# Must run AFTER check_version_sync — that step can `git add` version files
# and change the staged diff.
DIFF_HASH=$(git diff --cached | sha256sum | head -c 16)

# =============================================
# Test Coverage Analysis
# =============================================

run_test_coverage_agent() {
    if ! command -v claude >/dev/null 2>&1; then
        echo "${YELLOW}Claude CLI not found, skipping AI test analysis${NC}"
        return 0
    fi

    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' || true)
    if [ -z "$STAGED_FILES" ]; then
        return 0
    fi

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${BLUE}🧪 Test Coverage Analysis${NC}"
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    DIFF_CONTENT=$(git diff --cached)
    PROMPT="PRE-COMMIT TEST COVERAGE REVIEW.

$AGENT_OUTPUT_RULES

RUBRIC CONCERNS:
- new_tests: are there new functions/classes/branches in this diff that need tests?
- updated_tests: do existing tests need updates because behaviour under test changed?
- removed_tests: are there tests that still reference deleted code?

Use BLOCK if: new non-trivial functionality has zero test coverage; or existing tests will clearly fail; or tests reference deleted symbols.
Use WARN if: test additions would meaningfully improve confidence but aren't strictly required.

STAGED FILES:
$STAGED_FILES

DIFF:
$DIFF_CONTENT"

    file_count=$(count_lines "$STAGED_FILES")
    invoke_agent_with_cache "test-coverage" "qa-test-architect" "$PROMPT" "$file_count" "test-coverage"

    echo ""
