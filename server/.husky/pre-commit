#!/bin/sh

# =============================================
# Pre-commit Hook - Run Tests Before Commit
# =============================================
# This hook runs fast tests on changed files to catch issues early.
# For full test suite, run: npm run test:all
# =============================================

set -e

# Colors for output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

# Agent stop flags — populated from marker files after parallel wait
TEST_COVERAGE_STOP=0
UI_CONSISTENCY_STOP=0
BACKEND_QUALITY_STOP=0
DOCUMENTATION_STOP=0

echo "${YELLOW}Running pre-commit checks...${NC}"

# Get the repository root
REPO_ROOT=$(git rev-parse --show-toplevel)
GIT_DIR=$(git rev-parse --git-dir)

# =============================================
# Agent telemetry + cache infrastructure
# =============================================
# Telemetry appends one JSONL record per agent run to .claude/agent-audit.jsonl
# so verdicts can be reviewed periodically to tune prompts.
# Cache short-circuits claude invocation when an identical staged diff has been
# reviewed recently (common during `git commit --amend` and rebases).
# Both live under .claude/ which is gitignored — state stays local per-dev.

AGENT_LOG_DIR="$REPO_ROOT/.claude"
AGENT_LOG_FILE="$AGENT_LOG_DIR/agent-audit.jsonl"
AGENT_CACHE_DIR="$AGENT_LOG_DIR/agent-cache"
# Bump when any agent prompt changes to invalidate cache globally.
PROMPT_VERSION="v1"
# Per-commit scratch dir for parallel agent outputs and stop markers.
AGENT_TMP_DIR=$(mktemp -d -t sanctuary-agents-XXXXXX)
trap 'rm -rf "$AGENT_TMP_DIR"' EXIT

mkdir -p "$AGENT_LOG_DIR" "$AGENT_CACHE_DIR"

# TTL-sweep cache entries older than 7 days so the directory doesn't grow
# unbounded. Runs every commit — cheap operation, silent on empty cache.
find "$AGENT_CACHE_DIR" -type f -mtime +7 -delete 2>/dev/null || true

# Classify an agent's stdout. The prompts end with one of three
# marker phrases; UNKNOWN signals the agent ignored the rubric
# (itself useful for prompt tuning).
extract_verdict() {
    # $1 = path to agent output file
    if grep -q "RECOMMEND STOP" "$1"; then
        echo "STOP"
    elif grep -q "SUGGEST REVIEW" "$1"; then
        echo "REVIEW"
    elif grep -q "RECOMMEND PROCEED" "$1"; then
        echo "PROCEED"
    else
        echo "UNKNOWN"
    fi
}

# Count non-empty lines in a newline-separated list ("" → 0).
count_lines() {
    if [ -z "$1" ]; then
        echo 0
    else
        printf '%s\n' "$1" | wc -l | tr -d ' '
    fi
}

# Append one JSONL record per agent invocation. Cache hits log duration_s=0.
log_agent_run() {
    # $1=agent_name $2=verdict $3=duration_s $4=file_count $5=output_file $6=cache_hit(0|1)
    ts=$(date -u +%Y-%m-%dT%H:%M:%SZ)
    head=$(git rev-parse HEAD 2>/dev/null || echo "unknown")

    if command -v jq >/dev/null 2>&1; then
        jq -nc \
            --arg ts "$ts" \
            --arg head "$head" \
            --arg agent "$1" \
            --arg verdict "$2" \
            --arg duration_s "$3" \
            --arg file_count "$4" \
            --arg cache_hit "$6" \
            --rawfile output "$5" \
            '{timestamp:$ts, head:$head, agent:$agent, verdict:$verdict,
              duration_s:($duration_s|tonumber), file_count:($file_count|tonumber),
              cache_hit:($cache_hit=="1"), output:$output}' >> "$AGENT_LOG_FILE" 2>/dev/null || true
    else
        {
            echo "---"
            echo "timestamp=$ts head=$head agent=$1 verdict=$2 duration_s=$3 file_count=$4 cache_hit=$6"
            cat "$5"
        } >> "$AGENT_LOG_FILE" 2>/dev/null || true
    fi
}

# NOTE: DIFF_HASH is computed AFTER check_version_sync (below), because that
# function may `git add` version files and thereby change the staged diff.
# Computing it here would key the cache on the pre-sync diff while the agents
# review the post-sync diff — a silent correctness bug.
DIFF_HASH=""

# Run the agent unless the same (diff, agent, prompt-version) tuple has a
# cached verdict — in which case replay the cached output and skip claude.
# $1=agent_name $2=claude_agent_type(empty=general) $3=prompt
# $4=file_count $5=stop_marker_basename
# Writes to stdout: the full agent display (header + output + trailer).
# Touches $AGENT_TMP_DIR/$5.stop when the verdict is STOP.
invoke_agent_with_cache() {
    local agent_name="$1"
    local claude_agent="$2"
    local prompt="$3"
    local file_count="$4"
    local stop_name="$5"

    local cache_file="$AGENT_CACHE_DIR/${PROMPT_VERSION}-${DIFF_HASH}-${agent_name}.txt"

    if [ -f "$cache_file" ]; then
        cat "$cache_file"
        echo ""
        echo "${CYAN}(cache hit — identical diff reviewed previously)${NC}"
        local verdict
        verdict=$(extract_verdict "$cache_file")
        log_agent_run "$agent_name" "$verdict" 0 "$file_count" "$cache_file" 1
        if [ "$verdict" = "STOP" ]; then
            touch "$AGENT_TMP_DIR/${stop_name}.stop"
        fi
        return 0
    fi

    local start_time temp_output duration verdict
    start_time=$(date +%s)
    temp_output=$(mktemp)

    # `|| true` prevents set -e from aborting if claude itself errors —
    # we still want other agents to finish and a verdict of UNKNOWN logged.
    if [ -n "$claude_agent" ]; then
        echo "$prompt" | claude --agent "$claude_agent" --print > "$temp_output" 2>&1 || true
    else
        echo "$prompt" | claude --print > "$temp_output" 2>&1 || true
    fi

    cat "$temp_output"
    duration=$(( $(date +%s) - start_time ))
    verdict=$(extract_verdict "$temp_output")
    log_agent_run "$agent_name" "$verdict" "$duration" "$file_count" "$temp_output" 0
    cp "$temp_output" "$cache_file"

    if [ "$verdict" = "STOP" ]; then
        echo ""
        echo "${RED}❌ ${agent_name} agent recommends stopping. Please address the issues above.${NC}"
        echo "${YELLOW}To bypass: git commit --no-verify${NC}"
        touch "$AGENT_TMP_DIR/${stop_name}.stop"
    fi

    rm -f "$temp_output"
}

# =============================================
# Skip AI agents during non-interactive git ops
# =============================================
# Rebase/cherry-pick/merge replay commits without a human reviewing output,
# so AI agent feedback is wasted compute. Still run tests + version sync.

SKIP_AI_AGENTS=0
# Note: REBASE_HEAD intentionally excluded — git leaves it behind after a
# completed rebase, so it's unreliable. The rebase-merge/ and rebase-apply/
# directories are the authoritative "rebase in progress" signals.
if [ -f "$GIT_DIR/CHERRY_PICK_HEAD" ] \
   || [ -f "$GIT_DIR/MERGE_HEAD" ] \
   || [ -d "$GIT_DIR/rebase-merge" ] \
   || [ -d "$GIT_DIR/rebase-apply" ]; then
    SKIP_AI_AGENTS=1
fi

# =============================================
# Version Sync Check & Auto-Fix
# =============================================
# Verify all package.json and umbrel-app.yml versions are in sync
# If mismatched, automatically sync to root package.json version

check_version_sync() {
    cd "$REPO_ROOT"

    # Get root version
    ROOT_VER=$(grep '"version"' package.json | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')

    # Check each file
    SERVER_VER=$(grep '"version"' server/package.json | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')
    GATEWAY_VER=$(grep '"version"' gateway/package.json | head -1 | sed 's/.*"version": "\([^"]*\)".*/\1/')
    UMBREL_VER=$(grep '^version:' sanctuary/umbrel-app.yml | sed 's/version: "\([^"]*\)"/\1/')

    if [ "$ROOT_VER" != "$SERVER_VER" ] || [ "$ROOT_VER" != "$GATEWAY_VER" ] || [ "$ROOT_VER" != "$UMBREL_VER" ]; then
        echo ""
        echo "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo "${YELLOW}🔄 Version Mismatch Detected - Auto-syncing...${NC}"
        echo "${YELLOW}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
        echo ""
        echo "  package.json:             $ROOT_VER"
        echo "  server/package.json:      $SERVER_VER"
        echo "  gateway/package.json:     $GATEWAY_VER"
        echo "  sanctuary/umbrel-app.yml: $UMBREL_VER"
        echo ""
        echo "${CYAN}Syncing all versions to $ROOT_VER...${NC}"

        # Run the bump script to sync versions
        if ./scripts/bump-version.sh "$ROOT_VER" > /dev/null 2>&1; then
            echo "${GREEN}✓ Versions synced to $ROOT_VER${NC}"

            # Stage the updated version files
            git add package.json server/package.json gateway/package.json sanctuary/umbrel-app.yml
            echo "${GREEN}✓ Version files staged for commit${NC}"
        else
            echo "${RED}Failed to sync versions. Please run manually:${NC}"
            echo "${YELLOW}  ./scripts/bump-version.sh $ROOT_VER${NC}"
            exit 1
        fi
        echo ""
    fi
}

check_version_sync

# Hash the (possibly just-modified) staged diff. Serves as the cache key so
# amend-retry and identical rebase replays short-circuit claude invocation.
# Must run AFTER check_version_sync — that step can `git add` version files
# and change the staged diff.
DIFF_HASH=$(git diff --cached | sha256sum | head -c 16)

# =============================================
# Test Coverage Analysis
# =============================================
# Analyze if tests need to be added, updated, or removed

run_test_coverage_agent() {
    if ! command -v claude >/dev/null 2>&1; then
        echo "${YELLOW}Claude CLI not found, skipping AI test analysis${NC}"
        return 0
    fi

    STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' || true)
    if [ -z "$STAGED_FILES" ]; then
        return 0
    fi

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${BLUE}🧪 Test Coverage Analysis${NC}"
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    DIFF_CONTENT=$(git diff --cached)
    PROMPT="PRE-COMMIT TEST COVERAGE REVIEW

Analyze these staged changes and determine if tests need to be built, updated, or removed.

STAGED FILES:
$STAGED_FILES

DIFF:
$DIFF_CONTENT

Answer concisely:
1. Do any NEW tests need to be written? If so, what should they test?
2. Do any EXISTING tests need to be updated to match the changes?
3. Should any tests be REMOVED (e.g., testing deleted functionality)?

End with one of:
- ✅ RECOMMEND PROCEED - no test changes needed
- ⚠️ SUGGEST REVIEW - minor test updates may be helpful
- ❌ RECOMMEND STOP - tests should be updated before committing"

    file_count=$(count_lines "$STAGED_FILES")
    invoke_agent_with_cache "test-coverage" "qa-test-architect" "$PROMPT" "$file_count" "test-coverage"

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# =============================================
# UI Consistency & Style Analysis
# =============================================

run_ui_consistency_agent() {
    if ! command -v claude >/dev/null 2>&1; then
        return 0
    fi

    UI_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(components/|hooks/|contexts/).*\.tsx$' || true)
    if [ -z "$UI_FILES" ]; then
        return 0
    fi

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${BLUE}🎨 UI Consistency & Style Analysis${NC}"
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    UI_DIFF=$(git diff --cached -- $UI_FILES)
    PROMPT="PRE-COMMIT UI CONSISTENCY REVIEW

Analyze these UI changes for consistency with our existing codebase patterns.

STAGED UI FILES:
$UI_FILES

DIFF:
$UI_DIFF

Our codebase uses:
- Tailwind CSS with custom 'sanctuary' and 'primary' color palettes
- Dark mode support via 'dark:' prefix classes
- Consistent patterns: sanctuary-50 to sanctuary-950, primary-50 to primary-950
- Surface components and shared UI patterns in components/
- Common button styles, card layouts, modal patterns

Answer concisely:
1. Do the changes FIT the existing UI flow and component patterns?
2. Are there ONE-OFF custom styles that should use existing Tailwind classes or shared components instead?
3. Are dark mode styles properly implemented (dark: variants)?
4. Could any new UI be TEMPLATIZED using existing patterns?

End with one of:
- ✅ RECOMMEND PROCEED - UI changes are consistent
- ⚠️ SUGGEST REVIEW - minor style inconsistencies found
- ❌ RECOMMEND STOP - significant UI pattern violations"

    file_count=$(count_lines "$UI_FILES")
    invoke_agent_with_cache "ui-consistency" "ui-architect" "$PROMPT" "$file_count" "ui-consistency"

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# =============================================
# Backend Quality: Architecture + Stability (merged)
# =============================================

run_backend_quality_agent() {
    if ! command -v claude >/dev/null 2>&1; then
        return 0
    fi

    SOURCE_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' | grep -vE '(\.test\.|\.spec\.|/tests/)' || true)
    if [ -z "$SOURCE_FILES" ]; then
        return 0
    fi

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${BLUE}🏗️  Architecture & Stability Analysis${NC}"
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    QUALITY_DIFF=$(git diff --cached -- $SOURCE_FILES)
    PROMPT="PRE-COMMIT BACKEND QUALITY REVIEW

Analyze these changes for architectural soundness AND stability in long-running
operation. This codebase runs 24/7 without restarts, so both dimensions matter.

STAGED SOURCE FILES:
$SOURCE_FILES

DIFF:
$QUALITY_DIFF

Codebase constraints:
- Runs perpetually without restarts or memory growth
- Services must clean up intervals, timers, subscriptions, connections on shutdown
- External calls need circuit breakers, timeouts, or retry limits
- Collections (Map/Set/Array) must be bounded; caches must have size limits
- Code follows open/closed — extensible without modifying core logic
- Database operations transactional where correctness requires it

Answer concisely:
1. SCALABILITY: N+1 queries, unbounded iteration, blocking operations?
2. MEMORY SAFETY: Unbounded collections, growing caches, closure leaks?
3. RESOURCE CLEANUP: Intervals/timers/subscriptions/connections released?
4. FAILURE HANDLING: Circuit breakers, timeouts, retry limits on external calls?
5. EXTENSIBILITY: Open/closed violated? New code extending vs. modifying?

End with one of:
- ✅ RECOMMEND PROCEED - architecture and stability are sound
- ⚠️ SUGGEST REVIEW - minor concerns worth a look
- ❌ RECOMMEND STOP - significant scalability, memory, cleanup, or resilience issues"

    file_count=$(count_lines "$SOURCE_FILES")
    invoke_agent_with_cache "backend-quality" "lead-software-architect" "$PROMPT" "$file_count" "backend-quality"

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# =============================================
# Code Documentation Analysis
# =============================================

run_documentation_agent() {
    if ! command -v claude >/dev/null 2>&1; then
        return 0
    fi

    DOC_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(ts|tsx)$' | grep -vE '(\.test\.|\.spec\.|/tests/)' || true)
    if [ -z "$DOC_FILES" ]; then
        return 0
    fi

    CRITICAL_FILES=$(echo "$DOC_FILES" | grep -E '(bitcoin|crypto|key|sign|wallet|descriptor|address|transaction|auth|password|token|secret)' || true)

    # Skip for small non-security diffs
    if [ -z "$CRITICAL_FILES" ]; then
        DIFF_LINES=$(git diff --cached --stat | tail -1 | grep -oE '[0-9]+ insertion' | grep -oE '[0-9]+' || echo "0")
        if [ "$DIFF_LINES" -lt 50 ]; then
            return 0
        fi
    fi

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${BLUE}📚 Code Documentation Analysis${NC}"
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""

    DOC_DIFF=$(git diff --cached -- $DOC_FILES)
    PROMPT="PRE-COMMIT CODE DOCUMENTATION REVIEW

Analyze these changes for adequate documentation, especially for complex or security-critical code.

STAGED FILES:
$DOC_FILES

SECURITY-CRITICAL FILES DETECTED:
$CRITICAL_FILES

DIFF:
$DOC_DIFF

DOCUMENTATION REQUIREMENTS:
- Security-critical code (crypto, keys, signing, auth) MUST have clear documentation
- Complex algorithms or non-obvious logic should have explanatory comments
- Exported functions/types should have JSDoc describing purpose and parameters
- Bitcoin-specific logic (descriptors, derivation paths, script types) needs documentation
- Error handling rationale should be documented for non-obvious cases

Answer concisely:
1. SECURITY DOCUMENTATION: Is security-critical code (crypto, keys, auth, signing) adequately documented?
2. COMPLEXITY DOCUMENTATION: Are complex algorithms or non-obvious logic explained?
3. API DOCUMENTATION: Do new exported functions/types have JSDoc comments?
4. BITCOIN DOCUMENTATION: Is Bitcoin-specific logic (BIP standards, script types, derivation) documented?

End with one of:
- ✅ RECOMMEND PROCEED - documentation is adequate
- ⚠️ SUGGEST REVIEW - minor documentation improvements recommended
- ❌ RECOMMEND STOP - security-critical or complex code lacks essential documentation"

    file_count=$(count_lines "$DOC_FILES")
    # Empty claude_agent = use general-purpose
    invoke_agent_with_cache "documentation" "" "$PROMPT" "$file_count" "documentation"

    echo ""
    echo "${CYAN}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
}

# =============================================
# Launch AI agents in parallel
# =============================================
# Each agent runs in a background subshell with its own output file.
# Stop verdicts propagate via marker files in $AGENT_TMP_DIR (set -e +
# subshells would otherwise swallow the signal). After `wait`, outputs
# are replayed in deterministic order so the user sees consistent structure.
# Warning: this spawns up to 4 concurrent `claude` CLI processes — if the
# CLI ever imposes per-user concurrency limits this may need re-serialising.

run_and_report() {
    # $1 = function, $2 = order, $3 = display name
    "$1" > "$AGENT_TMP_DIR/${2}-${3}.log" 2>&1
    echo "${GREEN}✓${NC} ${3} complete" >&2
}

if [ "$SKIP_AI_AGENTS" = "1" ]; then
    echo ""
    echo "${YELLOW}Skipping AI agents — rebase/cherry-pick/merge in progress${NC}"
    echo ""
else
    echo ""
    echo "${CYAN}Running AI agents in parallel...${NC}"

    run_and_report run_test_coverage_agent   1 test-coverage &
    run_and_report run_ui_consistency_agent  2 ui-consistency &
    run_and_report run_backend_quality_agent 3 backend-quality &
    run_and_report run_documentation_agent   4 documentation &

    wait

    echo ""
    # Replay outputs in deterministic order regardless of completion order.
    for f in "$AGENT_TMP_DIR"/[0-9]-*.log; do
        [ -s "$f" ] && cat "$f" >&2
    done

    # Harvest stop markers from subshells.
    [ -f "$AGENT_TMP_DIR/test-coverage.stop" ]   && TEST_COVERAGE_STOP=1
    [ -f "$AGENT_TMP_DIR/ui-consistency.stop" ]  && UI_CONSISTENCY_STOP=1
    [ -f "$AGENT_TMP_DIR/backend-quality.stop" ] && BACKEND_QUALITY_STOP=1
    [ -f "$AGENT_TMP_DIR/documentation.stop" ]   && DOCUMENTATION_STOP=1
fi

# Check if any agent recommended stopping
if [ "$TEST_COVERAGE_STOP" = "1" ] || [ "$UI_CONSISTENCY_STOP" = "1" ] || [ "$BACKEND_QUALITY_STOP" = "1" ] || [ "$DOCUMENTATION_STOP" = "1" ]; then
    echo ""
    echo "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo "${RED}⛔ COMMIT BLOCKED - One or more agents recommend stopping${NC}"
    echo "${RED}━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━${NC}"
    echo ""
    echo "${YELLOW}Please address the issues above before committing.${NC}"
    echo "${YELLOW}To bypass: git commit --no-verify${NC}"
    echo ""
    exit 1
fi

# Check for staged files in different areas
BACKEND_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^server/' || true)
FRONTEND_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^(src/|components/|hooks/|tests/)' || true)

# Timeout for test runs (2 minutes)
TEST_TIMEOUT=120

# Check if Prisma schema changed and regenerate client
SCHEMA_CHANGED=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '^server/prisma/schema.prisma$' || true)
if [ -n "$SCHEMA_CHANGED" ]; then
    echo "${YELLOW}Prisma schema changed - regenerating client...${NC}"
    cd "$REPO_ROOT/server"
    npx prisma generate
    echo "${GREEN}Prisma client regenerated${NC}"
fi

# Run backend tests if backend files changed
if [ -n "$BACKEND_CHANGED" ]; then
    echo "${YELLOW}Backend files changed - running server tests...${NC}"
    cd "$REPO_ROOT/server"

    if timeout $TEST_TIMEOUT npm run test:fast 2>/dev/null; then
        echo "${GREEN}Backend tests passed${NC}"
    elif [ $? -eq 124 ]; then
        echo "${RED}Backend tests timed out after ${TEST_TIMEOUT}s. Commit aborted.${NC}"
        exit 1
    else
        echo "${RED}Backend tests failed. Commit aborted.${NC}"
        echo "Run 'cd server && npm test' for full output."
        exit 1
    fi
fi

# Run frontend tests if frontend files changed
if [ -n "$FRONTEND_CHANGED" ]; then
    echo "${YELLOW}Frontend files changed - running frontend tests...${NC}"
    cd "$REPO_ROOT"

    if timeout $TEST_TIMEOUT npm run test:run 2>/dev/null; then
        echo "${GREEN}Frontend tests passed${NC}"
    elif [ $? -eq 124 ]; then
        echo "${RED}Frontend tests timed out after ${TEST_TIMEOUT}s. Commit aborted.${NC}"
        exit 1
    else
        echo "${RED}Frontend tests failed. Commit aborted.${NC}"
        echo "Run 'npm run test:run' for full output."
        exit 1
    fi
fi

# If no relevant files changed, skip tests
if [ -z "$BACKEND_CHANGED" ] && [ -z "$FRONTEND_CHANGED" ]; then
    echo "${GREEN}No test-relevant files changed, skipping tests.${NC}"
fi

echo "${GREEN}Pre-commit checks passed!${NC}"
