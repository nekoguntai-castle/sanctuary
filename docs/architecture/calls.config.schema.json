{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://sanctuary.local/docs/architecture/calls.config.schema.json",
  "title": "Sanctuary call graph configuration",
  "type": "object",
  "additionalProperties": false,
  "required": ["subsystems"],
  "properties": {
    "$schema": {
      "type": "string"
    },
    "_comment": {
      "type": "string"
    },
    "subsystems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name", "title", "description", "include"],
        "properties": {
          "name": {
            "type": "string",
            "pattern": "^[a-z0-9][a-z0-9-]*$"
          },
          "title": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "include": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^(?!/)(?!.*(?:^|/)\\.\\.(?:/|$)).+"
            }
          }
        }
      }
    }
  }
}
