# Sanctuary Bitcoin Wallet - Environment Configuration
#
# RECOMMENDED: Run install.sh or scripts/setup.sh to generate this file
# automatically with secure random secrets.
#
# MANUAL SETUP: Copy this file to .env and update the required values:
#   cp .env.example .env
#
# IMPORTANT: Keep .env secure and never commit to version control!

# ============================================
# REQUIRED - Generate random strings for these
# ============================================

# JWT secret for authentication tokens (min 32 chars)
# Generate with: openssl rand -base64 32 | tr -d '=/+' | head -c 48
JWT_SECRET=CHANGE_ME_generate_a_random_string_here

# Encryption key for sensitive data like node passwords (min 32 chars)
# Generate with: openssl rand -base64 32 | tr -d '=/+' | head -c 48
ENCRYPTION_KEY=CHANGE_ME_generate_a_random_string_here

# Encryption salt for key derivation (REQUIRED in production)
# Generate with: openssl rand -base64 16
ENCRYPTION_SALT=CHANGE_ME_generate_a_random_salt

# Gateway secret for internal communication (min 32 chars)
# Used for HMAC signing between gateway and backend
# Generate with: openssl rand -base64 32 | tr -d '=/+' | head -c 48
GATEWAY_SECRET=CHANGE_ME_generate_a_random_string_here

# PostgreSQL database password (REQUIRED)
# Generate with: openssl rand -base64 16 | tr -d '=/+' | head -c 24
POSTGRES_PASSWORD=CHANGE_ME_generate_a_random_password

# ============================================
# PORTS
# ============================================

# HTTPS port (default: 8443)
HTTPS_PORT=8443

# HTTP port for redirect (default: 8080)
HTTP_PORT=8080

# Gateway port for mobile apps (default: 4000)
GATEWAY_PORT=4000

# Enable TLS for gateway (default: true for secure mobile connections)
GATEWAY_TLS_ENABLED=true

# ============================================
# OPTIONAL - Read-Only MCP Server
# ============================================

# MCP is disabled unless started with ./start.sh --with-mcp or the mcp Compose profile.
# Defaults publish the endpoint to host loopback only: http://127.0.0.1:3003/mcp
# For LAN exposure, use a TLS/VPN/reverse-proxy boundary and scoped, expiring MCP keys.
# MCP_BIND_ADDRESS=127.0.0.1
# MCP_PORT=3003
# MCP_ALLOWED_HOSTS=localhost,127.0.0.1,[::1]
# MCP_RATE_LIMIT_PER_MINUTE=120
# MCP_DEFAULT_PAGE_SIZE=100
# MCP_MAX_PAGE_SIZE=500
# MCP_MAX_DATE_RANGE_DAYS=365

# ============================================
# OPTIONAL - Bitcoin Network
# ============================================

# Bitcoin network: mainnet, testnet, signet, or regtest (default: mainnet)
BITCOIN_NETWORK=mainnet

# ============================================
# OPTIONAL - Worker
# ============================================

# Worker health endpoint used by backend readiness checks
# WORKER_HEALTH_URL=http://worker:3002/ready

# Optional worker health probe tuning (milliseconds)
# WORKER_HEALTH_TIMEOUT_MS=3000
# WORKER_HEALTH_CHECK_INTERVAL_MS=10000

# ============================================
# OPTIONAL - Custom Electrum Server
# ============================================

# Electrum server host (leave empty to use public servers)
# ELECTRUM_HOST=your-electrum-server.com
# ELECTRUM_PORT=50002
# ELECTRUM_SSL=true

# ============================================
# OPTIONAL - Logging
# ============================================

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# ============================================
# OPTIONAL - Security Settings
# ============================================

# CORS allowed browser origins (comma-separated; native/no-origin requests remain allowed)
# Example: https://app.example.com,https://admin.example.com
# CORS_ALLOWED_ORIGINS=

# JWT access token expiry (default: 1h)
# JWT_EXPIRES_IN=1h

# JWT refresh token expiry (default: 7d)
# JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# OPTIONAL - Payjoin (BIP78)
# ============================================

# Public URL for Payjoin endpoint (required for Payjoin behind NAT/Tor)
# This is the URL that sending wallets use to reach your BIP78 endpoint.
# Examples:
#   PAYJOIN_PUBLIC_URL=https://your-domain.com
#   PAYJOIN_PUBLIC_URL=http://your-onion-address.onion
# If unset, URL is auto-detected from the incoming request (only works for direct connections).
# PAYJOIN_PUBLIC_URL=

# ============================================
# OPTIONAL - AI Assistant
# ============================================

# AI container URL (default: http://ai:3100)
# Only change if running AI container on different host
# AI_CONTAINER_URL=http://ai:3100

# AI config sync secret (must match between backend and ai container)
# Used for backend-to-proxy authentication and secure config synchronization.
# Generate a unique value for real deployments:
#   openssl rand -hex 32
# AI_CONFIG_SECRET=sanctuary-ai-config-secret

# AI proxy endpoint egress policy.
# Local/container/LAN LLM endpoints are allowed by default:
#   ollama, localhost, host.docker.internal, *.local, 10/8, 172.16/12, 192.168/16, 127/8
# Public/cloud HTTPS endpoints are blocked unless explicitly allowed here
# or AI_PROXY_ALLOW_PUBLIC_HTTPS=true is set.
# AI_PROXY_ALLOWED_HOSTS=api.openai.com,*.trusted-llm.example
# AI_PROXY_ALLOWED_CIDRS=203.0.113.0/24
# AI_PROXY_ALLOW_PUBLIC_HTTPS=false

# ============================================
# OPTIONAL - Monitoring Stack (Grafana/Loki)
# ============================================
# Only required if using docker-compose.monitoring.yml

# Grafana admin password
# Default: uses ENCRYPTION_KEY (so you don't need another secret)
# Override if you want a different password for Grafana
# GRAFANA_PASSWORD=your-custom-grafana-password

# Grafana port (default: 3000)
# GRAFANA_PORT=3000

# ============================================
# OPTIONAL - Maintenance
# ============================================

# Disk usage warning threshold as a percentage (default: 80)
# The maintenance service will log warnings when Docker volumes exceed this threshold
# DISK_WARNING_THRESHOLD_PERCENT=80

# Audit log retention in days (default: 90)
# AUDIT_LOG_RETENTION_DAYS=90

# Price data retention in days (default: 30)
# PRICE_DATA_RETENTION_DAYS=30

# Fee estimate retention in days (default: 7)
# FEE_ESTIMATE_RETENTION_DAYS=7

# ============================================
# OPTIONAL - Push Notifications (Mobile App)
# ============================================
# See gateway/README.md for detailed setup instructions

# Apple Push Notification Service (iOS)
# Get these from Apple Developer Portal
# APNS_KEY_ID=
# APNS_TEAM_ID=
# APNS_BUNDLE_ID=
# APNS_PRODUCTION=false
# APNS_KEY_FILE=/path/to/apns-key.p8

# Firebase Cloud Messaging (Android)
# Download service account JSON from Firebase Console
# FCM_SERVICE_ACCOUNT=/path/to/fcm-service-account.json
